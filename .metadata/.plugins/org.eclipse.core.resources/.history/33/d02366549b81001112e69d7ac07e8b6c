<!DOCTYPE html>
<html lang="ko" xmlns:th="http://www.thymeleaf.org">
<head>
    <meta charset="UTF-8">
    <title>회원가입</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
    <link rel="stylesheet" th:href="@{/css/login.css}">
</head>
<body class="login-body">

<div class="login-card">
    <div class="login-header">
        <h2>Sign up</h2>
        <p>Enter Employee Information</p>
    </div>

    <form>
        <!-- 사원번호 -->
        <div class="form-section mb-3">
            <label class="form-label">사원번호</label>
            <div class="input-group">
                <input type="text" class="form-control" placeholder="사원번호 입력">
                <button type="button" class="btn btn-outline-primary">등록 여부 확인</button>
            </div>
        </div>

        <!-- 이름 -->
        <div class="form-section mb-3">
            <label class="form-label">이름</label>
            <input type="text" class="form-control" placeholder="이름 입력">
        </div>

        <!-- 비밀번호 -->
        <div class="form-section mb-4">
            <label class="form-label">비밀번호</label>
            <input type="password" class="form-control" placeholder="비밀번호 입력">
        </div>

        <div class="d-flex gap-2">
            <button type="submit" class="btn btn-primary w-50">회원가입</button>
            <button type="button" class="btn btn-secondary w-50" onclick="history.back()">뒤로가기</button>
        </div>
    </form>
</div>

</body>
</html>