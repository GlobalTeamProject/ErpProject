/* --- 기존 변수 유지 --- */
:root {
    --bg-color: #f4f7f6;
    --sidebar-bg: #ffffff;
    --main-bg: #ffffff;
    --text-main: #333333;
    --text-muted: #666666;
    --accent-color: #4a90e2;
    --hover-color: #eef5ff;
    --border-color: #e0e0e0;
}

* {
    box-sizing: border-box;
    margin: 0;
    padding: 0;
    font-family: 'Segoe UI', Roboto, sans-serif;
}

body {
    background-color: var(--bg-color);
    color: var(--text-main);
    height: 100vh;
    display: flex; /* 레이아웃을 위해 유지 */
    overflow: hidden; /* 페이지 전체 스크롤 방지 */
}

/* --- 전체 컨테이너 --- */
.dashboard-container {
    display: flex;
    width: 100vw; /* 꽉 차게 변경 */
    height: 100vh; /* 꽉 차게 변경 */
    background-color: var(--sidebar-bg);
}

/* --- 사이드바 --- */
.sidebar {
    width: 250px;
    display: flex;
    flex-direction: column;
    padding: 20px;
    border-right: 1px solid var(--border-color);
    flex-shrink: 0; /* 사이드바 크기 고정 */
}

.logo {
    font-size: 1.5rem;
    font-weight: bold;
    color: var(--accent-color);
    margin-bottom: 40px;
    display: flex;
    align-items: center;
    gap: 10px;
}

.nav-links {
    list-style: none;
    flex-grow: 1;
}

/* 핵심 변경 부분: button -> a 태그 스타일로 수정 */
.sidebar a {
    text-decoration: none;
    color: var(--text-muted);
    display: flex;
    align-items: center;
    gap: 15px;
    padding: 12px 15px;
    margin-bottom: 5px;
    border-radius: 8px;
    transition: all 0.2s;
    font-size: 1rem;
}

.sidebar a:hover {
    background-color: var(--hover-color);
    color: var(--accent-color);
}

.sidebar a.active {
    background-color: var(--accent-color);
    color: white;
}

.user-profile {
    margin-top: auto;
    display: flex;
    align-items: center;
    gap: 15px;
    padding: 15px;
    background-color: #f9f9f9;
    border-radius: 10px;
}

/* --- 메인 콘텐츠 --- */
.main-content {
    flex-grow: 1;
    background-color: var(--bg-color); /* 배경색 구분 */
    padding: 40px;
    overflow-y: auto; /* 콘텐츠가 길어지면 내부 스크롤 발생 */
}

