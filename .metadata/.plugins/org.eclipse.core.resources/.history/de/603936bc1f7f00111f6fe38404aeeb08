<!DOCTYPE html>
<html lang="ko" xmlns:th="http://www.thymeleaf.org">
<head>
    <meta charset="UTF-8">
    <title>시스템 로그인</title>
    <link rel="stylesheet" th:href="@{/css/login.css}">
</head>
<body class="login-body">
    <div class="login-card">
        <div class="login-header">
            <h2>ERP System</h2>
            <p>Enter your ID/PW</p>
        </div>
        <form action="/login" method="post">
            <div class="input-group">
                <label>Username</label>
                <input type="text" name="username" placeholder="Enter your ID" required>
            </div>
            <div class="input-group">
                <label>Password</label>
                <input type="password" name="password" placeholder="Enter Your pwd" required>
            </div>
            <button type="submit" class="login-btn">Login</button>
        </form>
        <div class="login-footer">
            <p align="center">Forgot your ID/PW? <br><a href="#">Find your ID</a> | <a href="#">Find your PW</a> |  <a href="#">Sign your ID/PW</a></p>
        </div>
    </div>
</body>
</html>