/* 전체 레이아웃 */
.container {
    display: flex;
    width: 800px;
    height: 400px;
    border: 2px solid black;
    margin: 50px auto; /* 중앙 정렬 */
}

/* 사이드바 스타일 */
.sidebar {
    width: 150px;
    padding: 20px;
    border-right: 2px solid black;
}

.sidebar button {
    display: block;
    width: 100%;
    margin-bottom: 10px;
    padding: 10px;
    cursor: pointer;
    background-color: #f0f0f0;
    border: 1px solid #ccc;
}

.sidebar button:hover {
    background-color: #ddd;
}

/* 콘텐츠 영역 스타일 */
.content {
    flex-grow: 1;
    padding: 20px;
}