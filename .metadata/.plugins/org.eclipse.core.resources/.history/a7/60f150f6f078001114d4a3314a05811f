<!DOCTYPE html>
<html lang="ko" xmlns:th="http://www.thymeleaf.org">
<head>
    <meta charset="UTF-8">
    <title>멋진 대시보드</title>
    <link rel="stylesheet" href="css/index_css.css">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
</head>
<body>

<div class="dashboard-container">
    <nav class="sidebar">
        <div class="logo">
            <i class="fas fa-code"></i> 
            <span>Dev Pro</span>
        </div>
        <ul class="nav-links">
            <li><button onclick="showContent('main')" class="active"><i class="fas fa-home"></i> 메인 페이지</button></li>
            <li><button onclick="showContent('1')"><i class="fas fa-chart-line"></i> 프로젝트 현황</button></li>
            <li><button onclick="showContent('2')"><i class="fas fa-users"></i> 팀원 관리</button></li>
            <li><button onclick="showContent('3')"><i class="fas fa-cog"></i> 시스템 설정</button></li>
            <li><button onclick="showContent('4')"><i class="fas fa-question-circle"></i> 도움말</button></li>
        </ul>
        <div class="user-profile">
            <img src="https://api.dicebear.com/8.x/avataaars/svg?seed=Felix" alt="User Avatar">
            <span>관리자님</span>
        </div>
    </nav>

    <main id="contentArea" class="main-content">
        <div class="welcome-card">
            <div class="card-icon">
                <i class="fas fa-tachometer-alt fa-3x"></i>
            </div>
            <div class="card-text">
                <h1>환영합니다, 관리자님!</h1>
                <p>왼쪽 메뉴를 선택하여 대시보드 항목을 확인하세요.</p>
            </div>
        </div>
        <div class="stats-grid">
            <div class="stat-card">오늘 방문자: 1,284</div>
            <div class="stat-card">활성 프로젝트: 5</div>
            <div class="stat-card">시스템 알림: 3</div>
        </div>
    </main>
</div>

<script>
    // 메뉴 버튼 활성화 상태 관리 함수
    function setActiveButton(menuId) {
        const buttons = document.querySelectorAll('.sidebar button');
        buttons.forEach(btn => btn.classList.remove('active'));
        // 클릭된 ID에 맞는 버튼 찾기 (main->메인페이지)
        let targetBtn;
        if(menuId === 'main') {
             targetBtn = document.querySelector(`.sidebar button[onclick="showContent('main')"]`);
        } else {
             targetBtn = document.querySelector(`.sidebar button[onclick="showContent('${menuId}')"]`);
        }
        if(targetBtn) targetBtn.classList.add('active');
    }

    function showContent(menuId) {
        const area = document.getElementById('contentArea');
        setActiveButton(menuId);

        const contents = {
            'main': `
                <div class="welcome-card">
                    <div class="card-icon"><i class="fas fa-tachometer-alt fa-3x"></i></div>
                    <div class="card-text">
                        <h1>환영합니다, 관리자님!</h1>
                        <p>왼쪽 메뉴를 선택하여 대시보드 항목을 확인하세요.</p>
                    </div>
                </div>
                <div class="stats-grid">
                    <div class="stat-card">오늘 방문자: 1,284</div>
                    <div class="stat-card">활성 프로젝트: 5</div>
                    <div class="stat-card">시스템 알림: 3</div>
                </div>
            `,
            '1': `
                <div class="content-header"><h2><i class="fas fa-chart-line"></i> 프로젝트 현황</h2></div>
                <div class="data-table">상세 프로젝트 데이터 로딩 중...</div>
            `,
            '2': `
                <div class="content-header"><h2><i class="fas fa-users"></i> 팀원 관리</h2></div>
                <div class="member-list">팀원 목록 및 권한 설정 화면</div>
            `,
            '3': `
                <div class="content-header"><h2><i class="fas fa-cog"></i> 시스템 설정</h2></div>
                <div class="settings-panel">환경 변수 및 서버 설정</div>
            `,
            '4': `
                <div class="content-header"><h2><i class="fas fa-question-circle"></i> 도움말</h2></div>
                <div class="help-section">자주 묻는 질문 및 매뉴얼</div>
            `
        };
        
        // 부드러운 전환 효과를 위한 애니메이션 클래스 추가
        area.style.opacity = '0';
        setTimeout(() => {
            area.innerHTML = contents[menuId];
            area.style.opacity = '1';
        }, 200);
    }
</script>

</body>
</html>