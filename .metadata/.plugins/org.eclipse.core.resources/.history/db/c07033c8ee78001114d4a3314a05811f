<!DOCTYPE html>
<html lang="ko">
<head>
    <meta charset="UTF-8">
    <title>메뉴 전환 페이지</title>
    <link rel="stylesheet" href="css/index_css.css">
</head>
<body>

<div class="container">
    <div class="sidebar">
        <button onclick="showContent('main')">메인</button>
        <button onclick="showContent('1')">1</button>
        <button onclick="showContent('2')">2</button>
        <button onclick="showContent('3')">3</button>
        <button onclick="showContent('4')">4</button>
    </div>
    
    <div id="contentArea" class="content">
        <h1>환영합니다!</h1>
        <p>메뉴를 선택해 주세요.</p>
    </div>
</div>

<script>
    function showContent(menuId) {
        const area = document.getElementById('contentArea');
        
        // 메뉴별 내용 정의
        const contents = {
            'main': '<h1>메인 페이지</h1><p>여기는 메인 화면입니다.</p>',
            '1': '<h1>항목 1</h1><p>이곳은 첫 번째 항목의 내용입니다.</p>',
            '2': '<h1>항목 2</h1><p>이곳은 두 번째 항목의 내용입니다.</p>',
            '3': '<h1>항목 3</h1><p>이곳은 세 번째 항목의 내용입니다.</p>',
            '4': '<h1>항목 4</h1><p>이곳은 네 번째 항목의 내용입니다.</p>'
        };
        
        area.innerHTML = contents[menuId];
    }
</script>

</body>
</html>