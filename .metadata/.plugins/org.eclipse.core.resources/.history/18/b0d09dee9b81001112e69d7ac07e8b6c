/* 기존 스타일은 유지 */
:root {
    --primary-color: #2563eb;
    --text-dark: #1e293b;
    --border-color: #e2e8f0;
}

body {
    margin: 0;
    padding: 0;
    font-family: 'Inter', sans-serif;
    background: linear-gradient(135deg, #f1f5f9 0%, #e2e8f0 100%);
    height: 100vh;
    display: flex;
    justify-content: center;
    align-items: center;
}

.login-card {
    background: white;
    padding: 40px;
    border-radius: 16px;
    box-shadow: 0 10px 25px rgba(0,0,0,0.05);
    width: 100%;
    max-width: 450px; /* 입력 필드가 많아 약간 넓게 조정 */
}

.login-header { text-align: center; margin-bottom: 30px; }
.login-header h2 { color: var(--text-dark); margin-bottom: 8px; }
.login-header p { color: #64748b; font-size: 14px; }

/* Bootstrap input 스타일 보완 */
.form-label { font-weight: 500; color: var(--text-dark); margin-bottom: 6px; }
.form-control { border-color: var(--border-color); padding: 10px; }
.form-control:focus { border-color: var(--primary-color); box-shadow: 0 0 0 0.2rem rgba(37, 99, 235, 0.1); }

/* 버튼 커스텀 (Bootstrap btn 클래스와 조화) */
.btn-primary { background-color: var(--primary-color); border: none; }
.btn-primary:hover { background-color: #1d4ed8; }