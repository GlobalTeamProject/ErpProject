/* --- 기본 스타일 및 변수 정의 --- */
:root {
    --bg-color: #121212; /* 전체 배경 */
    --sidebar-bg: #1e1e1e; /* 사이드바 배경 */
    --main-bg: #2c2c2c; /* 메인 콘텐츠 배경 */
    --text-main: #e0e0e0; /* 주요 텍스트 */
    --text-muted: #a0a0a0; /* 보조 텍스트 */
    --accent-color: #3f51b5; /* 포인트 컬러 (진한 파랑) */
    --hover-color: rgba(255,255,255,0.1); /* 호버 효과 */
    --border-color: #444;
}

* {
    box-sizing: border-box;
    margin: 0;
    padding: 0;
    font-family: 'Segoe UI', Roboto, Helvetica, Arial, sans-serif;
}

body {
    background-color: var(--bg-color);
    color: var(--text-main);
    height: 100vh;
    display: flex;
    justify-content: center;
    align-items: center;
}

/* --- 전체 컨테이너 --- */
.dashboard-container {
    display: flex;
    width: 95%;
    max-width: 1200px;
    height: 80vh;
    background-color: var(--sidebar-bg);
    border-radius: 15px;
    box-shadow: 0 10px 30px rgba(0,0,0,0.5);
    overflow: hidden;
}

/* --- 사이드바 스타일 --- */
.sidebar {
    width: 250px;
    display: flex;
    flex-direction: column;
    padding: 20px;
    border-right: 1px solid var(--border-color);
}

.logo {
    font-size: 1.5rem;
    font-weight: bold;
    color: var(--accent-color);
    margin-bottom: 40px;
    display: flex;
    align-items: center;
    gap: 10px;
}

.nav-links {
    list-style: none;
    flex-grow: 1;
}

.nav-links li {
    margin-bottom: 10px;
}

.sidebar button {
    background: none;
    border: none;
    color: var(--text-muted);
    width: 100%;
    padding: 12px 15px;
    text-align: left;
    cursor: pointer;
    border-radius: 8px;
    transition: all 0.3s;
    display: flex;
    align-items: center;
    gap: 15px;
    font-size: 1rem;
}

.sidebar button:hover {
    background-color: var(--hover-color);
    color: var(--text-main);
}

.sidebar button.active {
    background-color: var(--accent-color);
    color: white;
    font-weight: 600;
}

.user-profile {
    margin-top: auto;
    display: flex;
    align-items: center;
    gap: 15px;
    padding: 15px;
    background-color: rgba(0,0,0,0.2);
    border-radius: 10px;
}

.user-profile img {
    width: 40px;
    height: 40px;
    border-radius: 50%;
    border: 2px solid var(--accent-color);
}

/* --- 메인 콘텐츠 영역 스타일 --- */
.main-content {
    flex-grow: 1;
    background-color: var(--main-bg);
    padding: 40px;
    overflow-y: auto;
    transition: opacity 0.2s ease-in-out; /* 부드러운 전환 */
}

/* 스타일 예시: 메인 페이지 카드 */
.welcome-card {
    background: linear-gradient(135deg, #4caf50, #2e7d32); /* 초록색 그라데이션 */
    padding: 30px;
    border-radius: 15px;
    display: flex;
    align-items: center;
    gap: 20px;
    margin-bottom: 30px;
    color: white;
    box-shadow: 0 5px 15px rgba(0,0,0,0.2);
}

.welcome-card h1 { font-size: 2rem; margin-bottom: 10px; }
.welcome-card p { font-size: 1.1rem; opacity: 0.9; }

.stats-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(250px, 1fr));
    gap: 20px;
}

.stat-card {
    background-color: rgba(255,255,255,0.05);
    padding: 25px;
    border-radius: 12px;
    border: 1px solid var(--border-color);
    font-size: 1.2rem;
    font-weight: 500;
    color: var(--text-main);
    text-align: center;
}

/* 그 외 페이지 타이틀 스타일 */
.content-header {
    margin-bottom: 30px;
    border-bottom: 2px solid var(--accent-color);
    padding-bottom: 15px;
    color: var(--accent-color);
    display: flex;
    align-items: center;
    gap: 15px;
}
.content-header i { font-size: 1.8rem; }

/* --- 스크롤바 스타일 (웹킷 브라우저용) --- */
.main-content::-webkit-scrollbar { width: 8px; }
.main-content::-webkit-scrollbar-track { background: var(--main-bg); }
.main-content::-webkit-scrollbar-thumb { background: var(--border-color); border-radius: 4px; }